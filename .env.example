# LLM provider (optional). When disabled or misconfigured, tailoring stays local/deterministic.
CURSOR_USE_LLM=0
CURSOR_API_KEY=
CURSOR_OPENAI_BASE_URL=
# Pin one model for all tailor requests (use exact id from your provider model list).
CURSOR_PINNED_MODEL=claude-sonnet-4-6

# Cursor Cloud Agent API mode (preferred for true Cursor API usage).
CURSOR_USE_CLOUD_AGENT=0
CURSOR_API_BASE=https://api.cursor.com
CURSOR_SOURCE_REPOSITORY=
CURSOR_SOURCE_REF=
CURSOR_AGENT_MODEL=claude-4.6-opus-high-thinking
CURSOR_AGENT_TIMEOUT_S=180
